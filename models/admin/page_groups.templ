package admin

import (
	shared "bandcash/models/shared"
)

templ AdminGroupsPage(data DashboardData) {
	@shared.AdminLayout(shared.AdminLayoutProps{
		Title:           data.Title,
		Crumbs:          data.Breadcrumbs,
		Signals:         data.Signals,
		Content:         GroupsTableSection(data),
		ActiveTab:       "groups",
		ActiveUrl:       "/admin/groups",
		IsAuthenticated: data.IsAuthenticated,
		IsSuperAdmin:    data.IsSuperAdmin,
	})
}
