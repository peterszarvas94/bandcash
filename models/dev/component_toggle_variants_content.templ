package dev

import (
	shared "bandcash/models/shared"
)

templ ToggleVariantsContent() {
	<div class="row row-wrap">
		<div class="row items-center">
			@shared.ToggleSwitch(shared.ToggleSwitchProps{Bind: "switchOff", AriaLabel: "Toggle off"})
			<span class="text-sm">Toggle off</span>
		</div>
		<div class="row items-center">
			@shared.ToggleSwitch(shared.ToggleSwitchProps{Bind: "switchOn", AriaLabel: "Toggle on"})
			<span class="text-sm">Toggle on</span>
		</div>
		<div class="row items-center">
			@shared.ToggleSwitch(shared.ToggleSwitchProps{Bind: "switchDisabled", Disabled: true, AriaLabel: "Toggle off disabled"})
			<span class="text-sm">Toggle off (disabled)</span>
		</div>
	</div>
}
