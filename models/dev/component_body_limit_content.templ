package dev

import (
	"bandcash/internal/utils"
	shared "bandcash/models/shared"
)

templ BodyLimitContent() {
	<div class="row row-wrap">
		@shared.IDActionButton(shared.IDActionButtonProps{
			ID:        "body-limit-global-ok",
			ClassName: "btn",
			Label:     "POST /health (small body)",
		})
		@shared.IDActionButton(shared.IDActionButtonProps{
			ID:        "body-limit-global-big",
			ClassName: "btn",
			Label:     "POST /health (too large)",
		})
		@shared.IDActionButton(shared.IDActionButtonProps{
			ID:        "body-limit-auth-ok",
			ClassName: "btn",
			Label:     "POST /login (small body)",
		})
		@shared.IDActionButton(shared.IDActionButtonProps{
			ID:        "body-limit-auth-big",
			ClassName: "btn",
			Label:     "POST /login (too large)",
		})
		<button id="body-limit-clear" type="button" class="btn">
			Clear
		</button>
	</div>
	<input id="body-limit-csrf" type="hidden" value={ utils.CSRFTokenFromContext(ctx) }/>
	<span id="body-limit-msg-global-ok" hidden>Sending small payload to /health...</span>
	<span id="body-limit-msg-global-big" hidden>Sending oversized payload to /health...</span>
	<span id="body-limit-msg-auth-ok" hidden>Sending small payload to /login...</span>
	<span id="body-limit-msg-auth-big" hidden>Sending oversized payload to /login...</span>
	<span id="body-limit-msg-result" hidden>Result:</span>
	<pre id="body-limit-output">Ready.</pre>
}
