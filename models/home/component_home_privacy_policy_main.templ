package home

import ctxi18n "github.com/invopop/ctxi18n/i18n"
import shared "bandcash/models/shared"

templ HomePrivacyPolicyMain(currentLang string) {
	<section class="section">
		@shared.PageTitleWithLanguage(ctxi18n.T(ctx, "legal.privacy_policy"), "/privacy-policy", currentLang)
		@LegalPlaceholderBanner()
	</section>
}
