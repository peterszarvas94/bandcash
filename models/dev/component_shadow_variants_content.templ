package dev

templ ShadowVariantsContent() {
	<div class="field">
		<label>Surface: --bg-dark</label>
		<div class="row row-wrap" style="padding: var(--space); background: var(--bg-dark); border-radius: var(--radius);">
			<div class="field" style="max-width: 10rem;">
				<label>--shadow-sm</label>
				<div style="height: 6rem; border-radius: var(--radius); background: var(--bg-light); box-shadow: var(--shadow-sm);"></div>
			</div>
			<div class="field" style="max-width: 10rem;">
				<label>--shadow</label>
				<div style="height: 6rem; border-radius: var(--radius); background: var(--bg-light); box-shadow: var(--shadow);"></div>
			</div>
			<div class="field" style="max-width: 10rem;">
				<label>--shadow-lg</label>
				<div style="height: 6rem; border-radius: var(--radius); background: var(--bg-light); box-shadow: var(--shadow-lg);"></div>
			</div>
		</div>
	</div>
	<div class="field">
		<label>Surface: --bg</label>
		<div class="row row-wrap" style="padding: var(--space); background: var(--bg); border-radius: var(--radius);">
			<div class="field" style="max-width: 10rem;">
				<label>--shadow-sm</label>
				<div style="height: 6rem; border-radius: var(--radius); background: var(--bg-light); box-shadow: var(--shadow-sm);"></div>
			</div>
			<div class="field" style="max-width: 10rem;">
				<label>--shadow</label>
				<div style="height: 6rem; border-radius: var(--radius); background: var(--bg-light); box-shadow: var(--shadow);"></div>
			</div>
			<div class="field" style="max-width: 10rem;">
				<label>--shadow-lg</label>
				<div style="height: 6rem; border-radius: var(--radius); background: var(--bg-light); box-shadow: var(--shadow-lg);"></div>
			</div>
		</div>
	</div>
	<div class="field">
		<label>Surface: --bg-light</label>
		<div class="row row-wrap" style="padding: var(--space); background: var(--bg-light); border-radius: var(--radius);">
			<div class="field" style="max-width: 10rem;">
				<label>--shadow-sm</label>
				<div style="height: 6rem; border-radius: var(--radius); background: var(--bg-light); box-shadow: var(--shadow-sm);"></div>
			</div>
			<div class="field" style="max-width: 10rem;">
				<label>--shadow</label>
				<div style="height: 6rem; border-radius: var(--radius); background: var(--bg-light); box-shadow: var(--shadow);"></div>
			</div>
			<div class="field" style="max-width: 10rem;">
				<label>--shadow-lg</label>
				<div style="height: 6rem; border-radius: var(--radius); background: var(--bg-light); box-shadow: var(--shadow-lg);"></div>
			</div>
		</div>
	</div>
}
