package dev

import (
	shared "bandcash/models/shared"
)

templ RadioVariantsContent(linkSelector string) {
	<div class="field">
		<label>Client side (button)</label>
		<div class="row row-tight row-wrap">
			@shared.RadioButton(shared.RadioButtonProps{Bind: "radioDemo", Value: "1", Label: "Option", ClassName: "btn btn-xs", NoIcon: true})
			@shared.RadioButton(shared.RadioButtonProps{Bind: "radioDemo", Value: "2", Label: "Option", ClassName: "btn btn-xs", NoIcon: true})
			@shared.RadioButton(shared.RadioButtonProps{Bind: "radioDemo", Value: "3", Label: "Option", ClassName: "btn btn-xs", NoIcon: true})
		</div>
		<div class="row row-tight row-wrap">
			@shared.RadioButton(shared.RadioButtonProps{IsSelected: true, Label: "Disabled", ClassName: "btn btn-xs", DisabledExpr: "true", NoIcon: true})
			@shared.RadioButton(shared.RadioButtonProps{IsSelected: false, Label: "Disabled", ClassName: "btn btn-xs", DisabledExpr: "true", NoIcon: true})
			@shared.RadioButton(shared.RadioButtonProps{IsSelected: false, Label: "Disabled", ClassName: "btn btn-xs", DisabledExpr: "true", NoIcon: true})
		</div>
	</div>
	<div class="field">
		<label>Server side (link)</label>
		<div class="row row-tight row-wrap">
			@shared.RadioLink(shared.RadioLinkProps{Href: "/dev?selector=1", Label: "Option", IsSelected: linkSelector == "1", ClassName: "btn btn-xs", NoIcon: true})
			@shared.RadioLink(shared.RadioLinkProps{Href: "/dev?selector=2", Label: "Option", IsSelected: linkSelector == "2", ClassName: "btn btn-xs", NoIcon: true})
			@shared.RadioLink(shared.RadioLinkProps{Href: "/dev?selector=3", Label: "Option", IsSelected: linkSelector == "3", ClassName: "btn btn-xs", NoIcon: true})
		</div>
		<div class="row row-tight row-wrap">
			@shared.RadioLink(shared.RadioLinkProps{Href: "/dev?selector=1", Label: "Disabled", IsSelected: true, Disabled: true, ClassName: "btn btn-xs", NoIcon: true})
			@shared.RadioLink(shared.RadioLinkProps{Href: "/dev?selector=2", Label: "Disabled", IsSelected: false, Disabled: true, ClassName: "btn btn-xs", NoIcon: true})
			@shared.RadioLink(shared.RadioLinkProps{Href: "/dev?selector=3", Label: "Disabled", IsSelected: false, Disabled: true, ClassName: "btn btn-xs", NoIcon: true})
		</div>
	</div>
}
