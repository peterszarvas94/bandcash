package dev

import (
	"bandcash/internal/assets"
	appi18n "bandcash/internal/i18n"
	"bandcash/internal/utils"
	shared "bandcash/models/shared"
	icons "bandcash/models/shared/icons"
)

templ DevPage(linkSelector string) {
	<!DOCTYPE html>
	<html lang={ appi18n.LocaleCode(ctx) }>
		@shared.Head("Bandcash - Dev tools")
		<body>
			<div data-signals={ templ.JSONString(map[string]any{"csrf": utils.CSRFTokenFromContext(ctx), "errors": map[string]any{"name": ""}, "formData": map[string]any{"name": ""}, "_fetching": false, "activeSpinner": "", "_notifyInline": false, "_notifyInfo": false, "_notifySuccess": false, "_notifyWarning": false, "_notifyError": false, "toggleDefault": true, "toggleSuccess": true, "toggleWarning": true, "toggleDanger": true, "radioDemo": "all"}) } data-init="@get('/sse')"></div>
			@shared.Notifications()
			@shared.AppShellMainOnly("dev-page", []utils.Crumb{{Label: "Dev tools"}}, "", shared.DevPrimaryNav("dev"), DevMain(linkSelector))
			<script type="module" src={ assets.AssetPath("js/rate_limit_tester.js") }></script>
			<script type="module" src={ assets.AssetPath("js/body_limit_tester.js") }></script>
			<script type="module" src={ assets.AssetPath("js/table_query_tester.js") }></script>
		</body>
	</html>
}

templ DevMain(linkSelector string) {
	@shared.Section("Button variants", ButtonVariantsContent(linkSelector))
	@shared.Section("Toggle variants", ToggleVariantsContent())
	@shared.Section("Radio variants", RadioVariantsContent(linkSelector))
	@shared.Section("Form controls", FormControlsContent())
	@shared.Section("Notifications", NotificationsContent())
	@shared.Section("Email previews", EmailPreviewContent())
	@shared.Section("Error pages", ErrorPagePreviewContent())
	@shared.Section("Loading indicator test", LoadingIndicatorContent())
	@shared.Section("Table query tests", TableQueryTestContent())
	@shared.Section("Rate limit", RateLimitContent())
	@shared.Section("Body limit", BodyLimitContent())
}

templ ButtonVariantsContent(linkSelector string) {
	<div class="row row-wrap">
		<button class="btn" type="button">
			@icons.Plus(templ.Attributes{"class": "icon"})
			<span>Default</span>
		</button>
		<button class="btn btn-ghost" type="button">
			@icons.Info(templ.Attributes{"class": "icon"})
			<span>Ghost</span>
		</button>
		<button class="btn btn-active" type="button">
			@icons.Check(templ.Attributes{"class": "icon"})
			<span>Active</span>
		</button>
		<button class="btn btn-inactive" type="button">
			@icons.Icon(icons.IconBanknoteX, templ.Attributes{"class": "icon"})
			<span>Inactive</span>
		</button>
		<button class="btn" type="button" disabled>
			@icons.X(templ.Attributes{"class": "icon"})
			<span>Disabled</span>
		</button>
		<button class="btn btn-success" type="button">
			@icons.Check(templ.Attributes{"class": "icon"})
			<span>Success</span>
		</button>
		<button class="btn btn-warning" type="button">
			@icons.TriangleAlert(templ.Attributes{"class": "icon"})
			<span>Warning</span>
		</button>
		<button class="btn btn-danger" type="button">
			@icons.Trash2(templ.Attributes{"class": "icon"})
			<span>Danger</span>
		</button>
		<button class="btn btn-success" type="button" disabled>
			@icons.Check(templ.Attributes{"class": "icon"})
			<span>Success disabled</span>
		</button>
		<button class="btn btn-warning" type="button" disabled>
			@icons.TriangleAlert(templ.Attributes{"class": "icon"})
			<span>Warning disabled</span>
		</button>
		<button class="btn btn-danger" type="button" disabled>
			@icons.Trash2(templ.Attributes{"class": "icon"})
			<span>Danger disabled</span>
		</button>
	</div>
	<div class="row row-wrap">
		<button class="btn btn-sm" type="button">
			@icons.Plus(templ.Attributes{"class": "icon"})
			<span>Default</span>
		</button>
		<button class="btn btn-sm btn-ghost" type="button">
			@icons.Info(templ.Attributes{"class": "icon"})
			<span>Ghost</span>
		</button>
		<button class="btn btn-sm btn-active" type="button">
			@icons.Check(templ.Attributes{"class": "icon"})
			<span>Active</span>
		</button>
		<button class="btn btn-sm btn-inactive" type="button">
			@icons.Icon(icons.IconBanknoteX, templ.Attributes{"class": "icon"})
			<span>Inactive</span>
		</button>
		<button class="btn btn-sm" type="button" disabled>
			@icons.X(templ.Attributes{"class": "icon"})
			<span>Disabled</span>
		</button>
		<button class="btn btn-sm btn-success" type="button">
			@icons.Check(templ.Attributes{"class": "icon"})
			<span>Success</span>
		</button>
		<button class="btn btn-sm btn-warning" type="button">
			@icons.TriangleAlert(templ.Attributes{"class": "icon"})
			<span>Warning</span>
		</button>
		<button class="btn btn-sm btn-danger" type="button">
			@icons.Trash2(templ.Attributes{"class": "icon"})
			<span>Danger</span>
		</button>
		<button class="btn btn-sm btn-success" type="button" disabled>
			@icons.Check(templ.Attributes{"class": "icon"})
			<span>Success disabled</span>
		</button>
		<button class="btn btn-sm btn-warning" type="button" disabled>
			@icons.TriangleAlert(templ.Attributes{"class": "icon"})
			<span>Warning disabled</span>
		</button>
		<button class="btn btn-sm btn-danger" type="button" disabled>
			@icons.Trash2(templ.Attributes{"class": "icon"})
			<span>Danger disabled</span>
		</button>
	</div>
	<div class="row row-wrap">
		<button class="btn btn-xs" type="button">
			@icons.Plus(templ.Attributes{"class": "icon"})
			<span>Default</span>
		</button>
		<button class="btn btn-xs btn-ghost" type="button">
			@icons.Info(templ.Attributes{"class": "icon"})
			<span>Ghost</span>
		</button>
		<button class="btn btn-xs btn-active" type="button">
			@icons.Check(templ.Attributes{"class": "icon"})
			<span>Active</span>
		</button>
		<button class="btn btn-xs btn-inactive" type="button">
			@icons.Icon(icons.IconBanknoteX, templ.Attributes{"class": "icon"})
			<span>Inactive</span>
		</button>
		<button class="btn btn-xs" type="button" disabled>
			@icons.X(templ.Attributes{"class": "icon"})
			<span>Disabled</span>
		</button>
		<button class="btn btn-xs btn-success" type="button">
			@icons.Check(templ.Attributes{"class": "icon"})
			<span>Success</span>
		</button>
		<button class="btn btn-xs btn-warning" type="button">
			@icons.TriangleAlert(templ.Attributes{"class": "icon"})
			<span>Warning</span>
		</button>
		<button class="btn btn-xs btn-danger" type="button">
			@icons.Trash2(templ.Attributes{"class": "icon"})
			<span>Danger</span>
		</button>
		<button class="btn btn-xs btn-success" type="button" disabled>
			@icons.Check(templ.Attributes{"class": "icon"})
			<span>Success disabled</span>
		</button>
		<button class="btn btn-xs btn-warning" type="button" disabled>
			@icons.TriangleAlert(templ.Attributes{"class": "icon"})
			<span>Warning disabled</span>
		</button>
		<button class="btn btn-xs btn-danger" type="button" disabled>
			@icons.Trash2(templ.Attributes{"class": "icon"})
			<span>Danger disabled</span>
		</button>
	</div>
	<div class="row row-wrap">
		<button class="btn btn-icon" type="button" aria-label="Default icon" title="Default icon">
			@icons.Plus(templ.Attributes{"class": "icon"})
		</button>
		<button class="btn btn-ghost btn-icon" type="button" aria-label="Ghost icon" title="Ghost icon">
			@icons.Info(templ.Attributes{"class": "icon"})
		</button>
		<button class="btn btn-active btn-icon" type="button" aria-label="Active icon" title="Active icon">
			@icons.Check(templ.Attributes{"class": "icon"})
		</button>
		<button class="btn btn-inactive btn-icon" type="button" aria-label="Inactive icon" title="Inactive icon">
			@icons.Icon(icons.IconBanknoteX, templ.Attributes{"class": "icon"})
		</button>
		<button class="btn btn-icon" type="button" aria-label="Disabled icon" title="Disabled icon" disabled>
			@icons.X(templ.Attributes{"class": "icon"})
		</button>
		<button class="btn btn-success btn-icon" type="button" aria-label="Success icon" title="Success icon">
			@icons.Check(templ.Attributes{"class": "icon"})
		</button>
		<button class="btn btn-warning btn-icon" type="button" aria-label="Warning icon" title="Warning icon">
			@icons.TriangleAlert(templ.Attributes{"class": "icon"})
		</button>
		<button class="btn btn-danger btn-icon" type="button" aria-label="Danger icon" title="Danger icon">
			@icons.Trash2(templ.Attributes{"class": "icon"})
		</button>
		<button class="btn btn-success btn-icon" type="button" aria-label="Success icon disabled" title="Success icon disabled" disabled>
			@icons.Check(templ.Attributes{"class": "icon"})
		</button>
		<button class="btn btn-warning btn-icon" type="button" aria-label="Warning icon disabled" title="Warning icon disabled" disabled>
			@icons.TriangleAlert(templ.Attributes{"class": "icon"})
		</button>
		<button class="btn btn-danger btn-icon" type="button" aria-label="Danger icon disabled" title="Danger icon disabled" disabled>
			@icons.Trash2(templ.Attributes{"class": "icon"})
		</button>
	</div>
	<div class="row row-wrap">
		<button class="btn btn-sm btn-icon" type="button" aria-label="Small default icon" title="Small default icon">
			@icons.Plus(templ.Attributes{"class": "icon"})
		</button>
		<button class="btn btn-sm btn-ghost btn-icon" type="button" aria-label="Small ghost icon" title="Small ghost icon">
			@icons.Info(templ.Attributes{"class": "icon"})
		</button>
		<button class="btn btn-sm btn-active btn-icon" type="button" aria-label="Small active icon" title="Small active icon">
			@icons.Check(templ.Attributes{"class": "icon"})
		</button>
		<button class="btn btn-sm btn-inactive btn-icon" type="button" aria-label="Small inactive icon" title="Small inactive icon">
			@icons.Icon(icons.IconBanknoteX, templ.Attributes{"class": "icon"})
		</button>
		<button class="btn btn-sm btn-icon" type="button" aria-label="Small disabled icon" title="Small disabled icon" disabled>
			@icons.X(templ.Attributes{"class": "icon"})
		</button>
		<button class="btn btn-sm btn-success btn-icon" type="button" aria-label="Small success icon" title="Small success icon">
			@icons.Check(templ.Attributes{"class": "icon"})
		</button>
		<button class="btn btn-sm btn-warning btn-icon" type="button" aria-label="Small warning icon" title="Small warning icon">
			@icons.TriangleAlert(templ.Attributes{"class": "icon"})
		</button>
		<button class="btn btn-sm btn-danger btn-icon" type="button" aria-label="Small danger icon" title="Small danger icon">
			@icons.Trash2(templ.Attributes{"class": "icon"})
		</button>
		<button class="btn btn-sm btn-success btn-icon" type="button" aria-label="Small success icon disabled" title="Small success icon disabled" disabled>
			@icons.Check(templ.Attributes{"class": "icon"})
		</button>
		<button class="btn btn-sm btn-warning btn-icon" type="button" aria-label="Small warning icon disabled" title="Small warning icon disabled" disabled>
			@icons.TriangleAlert(templ.Attributes{"class": "icon"})
		</button>
		<button class="btn btn-sm btn-danger btn-icon" type="button" aria-label="Small danger icon disabled" title="Small danger icon disabled" disabled>
			@icons.Trash2(templ.Attributes{"class": "icon"})
		</button>
	</div>
	<div class="row row-wrap">
		<button class="btn btn-xs btn-icon" type="button" aria-label="Extra small default icon" title="Extra small default icon">
			@icons.Plus(templ.Attributes{"class": "icon"})
		</button>
		<button class="btn btn-xs btn-ghost btn-icon" type="button" aria-label="Extra small ghost icon" title="Extra small ghost icon">
			@icons.Info(templ.Attributes{"class": "icon"})
		</button>
		<button class="btn btn-xs btn-active btn-icon" type="button" aria-label="Extra small active icon" title="Extra small active icon">
			@icons.Check(templ.Attributes{"class": "icon"})
		</button>
		<button class="btn btn-xs btn-inactive btn-icon" type="button" aria-label="Extra small inactive icon" title="Extra small inactive icon">
			@icons.Icon(icons.IconBanknoteX, templ.Attributes{"class": "icon"})
		</button>
		<button class="btn btn-xs btn-icon" type="button" aria-label="Extra small disabled icon" title="Extra small disabled icon" disabled>
			@icons.X(templ.Attributes{"class": "icon"})
		</button>
		<button class="btn btn-xs btn-success btn-icon" type="button" aria-label="Extra small success icon" title="Extra small success icon">
			@icons.Check(templ.Attributes{"class": "icon"})
		</button>
		<button class="btn btn-xs btn-warning btn-icon" type="button" aria-label="Extra small warning icon" title="Extra small warning icon">
			@icons.TriangleAlert(templ.Attributes{"class": "icon"})
		</button>
		<button class="btn btn-xs btn-danger btn-icon" type="button" aria-label="Extra small danger icon" title="Extra small danger icon">
			@icons.Trash2(templ.Attributes{"class": "icon"})
		</button>
		<button class="btn btn-xs btn-success btn-icon" type="button" aria-label="Extra small success icon disabled" title="Extra small success icon disabled" disabled>
			@icons.Check(templ.Attributes{"class": "icon"})
		</button>
		<button class="btn btn-xs btn-warning btn-icon" type="button" aria-label="Extra small warning icon disabled" title="Extra small warning icon disabled" disabled>
			@icons.TriangleAlert(templ.Attributes{"class": "icon"})
		</button>
		<button class="btn btn-xs btn-danger btn-icon" type="button" aria-label="Extra small danger icon disabled" title="Extra small danger icon disabled" disabled>
			@icons.Trash2(templ.Attributes{"class": "icon"})
		</button>
	</div>
	<div class="row row-wrap">
	</div>
}

templ ToggleVariantsContent() {
	<div class="row row-wrap">
		@shared.Toggle(shared.ToggleProps{
			Bind:         "toggleDefault",
			DisabledExpr: "$_fetching",
			Off:          "Toggle off",
			On:           "Toggle on",
		})
		@shared.Toggle(shared.ToggleProps{
			Bind:         "toggleSuccess",
			DisabledExpr: "$_fetching",
			Off:          "Toggle off",
			On:           "Toggle on",
			OnClass:      "btn-success",
		})
		@shared.Toggle(shared.ToggleProps{
			Bind:         "toggleWarning",
			DisabledExpr: "$_fetching",
			Off:          "Toggle off",
			On:           "Toggle on",
			OnClass:      "btn-warning",
		})
		@shared.Toggle(shared.ToggleProps{
			Bind:         "toggleDanger",
			DisabledExpr: "$_fetching",
			Off:          "Toggle off",
			On:           "Toggle on",
			OnClass:      "btn-danger",
		})
	</div>
	<div class="row row-wrap">
		@shared.Toggle(shared.ToggleProps{IsOn: true, Disabled: true, Off: "Toggle off", On: "Toggle on (disabled)"})
		@shared.Toggle(shared.ToggleProps{IsOn: true, Disabled: true, Off: "Toggle off", On: "Toggle on (disabled)", OnClass: "btn-success"})
		@shared.Toggle(shared.ToggleProps{IsOn: true, Disabled: true, Off: "Toggle off", On: "Toggle on (disabled)", OnClass: "btn-warning"})
		@shared.Toggle(shared.ToggleProps{IsOn: true, Disabled: true, Off: "Toggle off", On: "Toggle on (disabled)", OnClass: "btn-danger"})
	</div>
	<div class="row row-wrap">
		@shared.Toggle(shared.ToggleProps{IsOn: false, Disabled: true, Off: "Toggle off (disabled)", On: "Toggle on"})
		@shared.Toggle(shared.ToggleProps{IsOn: false, Disabled: true, Off: "Toggle off (disabled)", On: "Toggle on", OnClass: "btn-success"})
		@shared.Toggle(shared.ToggleProps{IsOn: false, Disabled: true, Off: "Toggle off (disabled)", On: "Toggle on", OnClass: "btn-warning"})
		@shared.Toggle(shared.ToggleProps{IsOn: false, Disabled: true, Off: "Toggle off (disabled)", On: "Toggle on", OnClass: "btn-danger"})
	</div>
}

templ RadioVariantsContent(linkSelector string) {
	<div class="field">
		<label>Client side (button)</label>
		<div class="row row-tight row-wrap">
			@shared.RadioButton(shared.RadioButtonProps{Bind: "radioDemo", Value: "all", Label: "All", ClassName: "btn btn-xs"})
			@shared.RadioButton(shared.RadioButtonProps{Bind: "radioDemo", Value: "paid", Label: "Paid", ClassName: "btn btn-xs"})
			@shared.RadioButton(shared.RadioButtonProps{Bind: "radioDemo", Value: "unpaid", Label: "Unpaid", ClassName: "btn btn-xs"})
		</div>
		<div class="row row-tight row-wrap">
			@shared.RadioButton(shared.RadioButtonProps{Bind: "radioDemo", Value: "all", Label: "All (disabled)", ClassName: "btn btn-xs", DisabledExpr: "true"})
			@shared.RadioButton(shared.RadioButtonProps{Bind: "radioDemo", Value: "paid", Label: "Paid (disabled)", ClassName: "btn btn-xs", DisabledExpr: "true"})
			@shared.RadioButton(shared.RadioButtonProps{Bind: "radioDemo", Value: "unpaid", Label: "Unpaid (disabled)", ClassName: "btn btn-xs", DisabledExpr: "true"})
		</div>
	</div>
	<div class="field">
		<label>Server side (link)</label>
		<div class="row row-tight row-wrap">
			@shared.RadioLink(shared.RadioLinkProps{Href: "/dev?selector=all", Label: "All", IsSelected: linkSelector == "all", ClassName: "btn btn-xs"})
			@shared.RadioLink(shared.RadioLinkProps{Href: "/dev?selector=2026", Label: "2026", IsSelected: linkSelector == "2026", ClassName: "btn btn-xs"})
			@shared.RadioLink(shared.RadioLinkProps{Href: "/dev?selector=custom", Label: "Custom", IsSelected: linkSelector == "custom", ClassName: "btn btn-xs"})
		</div>
		<div class="row row-tight row-wrap">
			@shared.RadioLink(shared.RadioLinkProps{Href: "/dev?selector=all", Label: "All (disabled)", IsSelected: linkSelector == "all", Disabled: true, ClassName: "btn btn-xs"})
			@shared.RadioLink(shared.RadioLinkProps{Href: "/dev?selector=2026", Label: "2026 (disabled)", IsSelected: linkSelector == "2026", Disabled: true, ClassName: "btn btn-xs"})
			@shared.RadioLink(shared.RadioLinkProps{Href: "/dev?selector=custom", Label: "Custom (disabled)", IsSelected: linkSelector == "custom", Disabled: true, ClassName: "btn btn-xs"})
		</div>
	</div>
}

templ FormControlsContent() {
	<div class="row row-wrap">
		<input class="input w-half" type="text" placeholder="Input placeholder" value="Input value"/>
		<select class="input w-half">
			<option>Alpha</option>
			<option selected>Selected option</option>
			<option>Gamma</option>
		</select>
	</div>
	<div class="row row-wrap">
		<textarea class="input" rows="6">Textarea sample text</textarea>
	</div>
	<div class="row row-wrap">
		<input class="input w-half" type="text" placeholder="Disabled input" value="Disabled input" disabled/>
		<select class="input w-half" disabled>
			<option selected>Disabled select</option>
		</select>
	</div>
	<div class="row row-wrap">
		<textarea class="input" rows="6" disabled>Disabled textarea</textarea>
	</div>
	<div class="row row-wrap">
		<input class="input input-sm w-half" type="text" placeholder="Small input placeholder" value="Small input value"/>
		<select class="input input-sm w-half">
			<option>Small alpha</option>
			<option selected>Small selected option</option>
			<option>Small gamma</option>
		</select>
	</div>
	<div class="row row-wrap">
		<textarea class="input input-sm" rows="3">Small textarea sample text</textarea>
	</div>
	<div class="row row-wrap">
		<input class="input input-sm w-half" type="text" placeholder="Small disabled input" value="Small disabled input" disabled/>
		<select class="input input-sm w-half" disabled>
			<option selected>Small disabled select</option>
		</select>
	</div>
	<div class="row row-wrap">
		<textarea class="input input-sm" rows="3" disabled>Small disabled textarea</textarea>
	</div>
}

templ TableQueryTestContent() {
	<div class="row row-wrap">
		@shared.IDActionButton(shared.IDActionButtonProps{
			ID:        "query-test-events-valid",
			ClassName: "btn",
			Label:     "Events valid query",
		})
		@shared.IDActionButton(shared.IDActionButtonProps{
			ID:        "query-test-events-invalid",
			ClassName: "btn",
			Label:     "Events invalid values",
		})
		@shared.IDActionButton(shared.IDActionButtonProps{
			ID:        "query-test-members-valid",
			ClassName: "btn",
			Label:     "Members valid query",
		})
		@shared.IDActionButton(shared.IDActionButtonProps{
			ID:        "query-test-expenses-valid",
			ClassName: "btn",
			Label:     "Expenses valid query",
		})
		<button id="query-test-clear" type="button" class="btn">
			Clear
		</button>
	</div>
	<pre id="query-test-output">Ready.</pre>
}

templ EmailPreviewContent() {
	<div class="row row-wrap">
		<a class="btn" href="/dev/emails/login" target="_blank" rel="noopener">Login email</a>
		<a class="btn" href="/dev/emails/invite" target="_blank" rel="noopener">Invite email</a>
		<a class="btn" href="/dev/emails/invite-accepted" target="_blank" rel="noopener">Invite accepted email</a>
		<a class="btn" href="/dev/emails/group-created" target="_blank" rel="noopener">Group created email</a>
		<a class="btn" href="/dev/emails/role-upgraded" target="_blank" rel="noopener">Role upgraded email</a>
		<a class="btn" href="/dev/emails/role-downgraded" target="_blank" rel="noopener">Role downgraded email</a>
		<a class="btn" href="/dev/emails/access-removed" target="_blank" rel="noopener">Access removed email</a>
	</div>
}

