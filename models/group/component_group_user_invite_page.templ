package group

import (
	shared "bandcash/models/shared"
)

templ GroupUserInvitePage(data UserInvitePageData) {
	@shared.GroupLayout(shared.GroupLayoutProps{
		Title:           data.Title,
		Crumbs:          data.Breadcrumbs,
		Signals:         data.Signals,
		Content:         GroupUserInviteMain(data),
		ActiveUrl:       "/groups",
		IsAuthenticated: data.IsAuthenticated,
		IsSuperAdmin:    data.IsSuperAdmin,
		GroupId:         data.GroupID,
		ActiveTab:       "users",
	})
}
