package dev

import (
	"bandcash/internal/assets"
	appi18n "bandcash/internal/i18n"
	"bandcash/internal/utils"
	shared "bandcash/models/shared"
)

templ DevPage(linkSelector string, isAuthenticated bool, userEmail string) {
	{{ tabID := utils.GenerateID("tab") }}
	@shared.HomeLayout(
		"dev-page",
		"Bandcash - Dev tools",
		map[string]any{"tab_id": tabID, "csrf": utils.CSRFTokenFromContext(ctx), "errors": map[string]any{"name": ""}, "formData": map[string]any{"name": ""}, "_fetching": false, "activeSpinner": "", "_notifyInline": false, "_notifyInfo": false, "_notifySuccess": false, "_notifyError": false, "toggleDefault": true, "toggleSuccess": true, "toggleDanger": true, "radioDemo": "all"},
		[]utils.Crumb{{Label: "Dev tools"}},
		userEmail,
		appi18n.LocaleCode(ctx),
		"/dev",
		isAuthenticated,
		DevMain(linkSelector),
	)
	<script type="module" src={ assets.AssetPath("js/rate_limit_tester.js") }></script>
	<script type="module" src={ assets.AssetPath("js/body_limit_tester.js") }></script>
	<script type="module" src={ assets.AssetPath("js/table_query_tester.js") }></script>
}
