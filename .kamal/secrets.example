# 1Password source config
# Fill these values, then Kamal will fetch all secrets below.
# account USER ID from `op account list` (URL/email may not work here)
OP_ACCOUNT=XXXXXXXXXXXXXXXXXXXXXXXXXX
# full 1Password path passed to --from (for example: Bandcash/prod)
OP_FROM=Bandcash/prod

# Fetch all required values (clear + secret) once, then extract by key name.
SECRETS=$(kamal secrets fetch --adapter 1password --account "$OP_ACCOUNT" --from "$OP_FROM" APP_ENV HOST PORT URL DB_PATH LOG_LEVEL LOG_FOLDER LOG_PREFIX DISABLE_RATE_LIMIT PADDLE_ENV KAMAL_REGISTRY_USERNAME KAMAL_REGISTRY_PASSWORD SUPERADMIN_EMAIL SMTP_HOST SMTP_PORT EMAIL_FROM SMTP_USERNAME SMTP_PASSWORD PADDLE_API_KEY PADDLE_API_BASE_URL PADDLE_CLIENT_TOKEN PADDLE_WEBHOOK_SECRET PADDLE_PRICE_ID BETTER_STACK_URI BETTER_STACK_SOURCE_TOKEN)

KAMAL_REGISTRY_USERNAME=$(kamal secrets extract KAMAL_REGISTRY_USERNAME $SECRETS)
KAMAL_REGISTRY_PASSWORD=$(kamal secrets extract KAMAL_REGISTRY_PASSWORD $SECRETS)

APP_ENV=$(kamal secrets extract APP_ENV $SECRETS)
HOST=$(kamal secrets extract HOST $SECRETS)
PORT=$(kamal secrets extract PORT $SECRETS)
URL=$(kamal secrets extract URL $SECRETS)
DB_PATH=$(kamal secrets extract DB_PATH $SECRETS)
LOG_LEVEL=$(kamal secrets extract LOG_LEVEL $SECRETS)
LOG_FOLDER=$(kamal secrets extract LOG_FOLDER $SECRETS)
LOG_PREFIX=$(kamal secrets extract LOG_PREFIX $SECRETS)

SUPERADMIN_EMAIL=$(kamal secrets extract SUPERADMIN_EMAIL $SECRETS)
SMTP_HOST=$(kamal secrets extract SMTP_HOST $SECRETS)
SMTP_PORT=$(kamal secrets extract SMTP_PORT $SECRETS)
SMTP_USERNAME=$(kamal secrets extract SMTP_USERNAME $SECRETS)
SMTP_PASSWORD=$(kamal secrets extract SMTP_PASSWORD $SECRETS)
EMAIL_FROM=$(kamal secrets extract EMAIL_FROM $SECRETS)

PADDLE_ENV=$(kamal secrets extract PADDLE_ENV $SECRETS)
PADDLE_API_BASE_URL=$(kamal secrets extract PADDLE_API_BASE_URL $SECRETS)
PADDLE_API_KEY=$(kamal secrets extract PADDLE_API_KEY $SECRETS)
PADDLE_CLIENT_TOKEN=$(kamal secrets extract PADDLE_CLIENT_TOKEN $SECRETS)
PADDLE_WEBHOOK_SECRET=$(kamal secrets extract PADDLE_WEBHOOK_SECRET $SECRETS)
PADDLE_PRICE_ID=$(kamal secrets extract PADDLE_PRICE_ID $SECRETS)

BETTER_STACK_URI=$(kamal secrets extract BETTER_STACK_URI $SECRETS)
BETTER_STACK_SOURCE_TOKEN=$(kamal secrets extract BETTER_STACK_SOURCE_TOKEN $SECRETS)

DISABLE_RATE_LIMIT=$(kamal secrets extract DISABLE_RATE_LIMIT $SECRETS)
