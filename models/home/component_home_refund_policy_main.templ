package home

import ctxi18n "github.com/invopop/ctxi18n/i18n"
import shared "bandcash/models/shared"

templ HomeRefundPolicyMain(currentLang string) {
	<section class="section">
		@shared.PageLanguagePicker("/refund-policy", currentLang)
		<header>
			<h1>{ ctxi18n.T(ctx, "legal.refund_policy") }</h1>
		</header>
		@LegalPlaceholderBanner()
	</section>
}
