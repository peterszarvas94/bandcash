package shared

	type DetailsRow struct {
		Label      string
		LabelClass string
	Value      string
	ValueClass string
	Action     templ.Component
}

templ DetailsCard(stateKey string, rows []DetailsRow) {
	{{
		_ = stateKey
		rowsBody := rows
	}}
	<section class="detail-box">
		<dl>
			for _, row := range rowsBody {
				if row.LabelClass != "section-title" {
					<div>
						<dt>{ row.Label }</dt>
						<dd>
							if row.Action != nil {
								@row.Action
							}
							{ row.Value }
						</dd>
					</div>
				}
			}
		</dl>
	</section>
}

templ DetailsSection(stateKey string, rows []DetailsRow) {
	<div class="pb">
		@DetailsCard(stateKey, rows)
	</div>
}

templ DetailsActions(actions templ.Component) {
	<div class="detail-actions">
		@actions
	</div>
}

templ Details(summary string, content templ.Component) {
	{{ _ = summary }}
	<div class="pb">
		<div class="detail-box">
			@content
		</div>
	</div>
}
