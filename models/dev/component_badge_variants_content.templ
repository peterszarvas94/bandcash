package dev

import shared "bandcash/models/shared"

templ BadgeVariantsContent() {
	<div class="field">
		<label>Base badge</label>
		<div class="row row-wrap">
			@shared.Badge("default")
		</div>
	</div>
	<div class="field">
		<label>Role variants</label>
		<div class="row row-wrap">
			@shared.Badge("owner")
			@shared.Badge("admin")
			@shared.Badge("viewer")
		</div>
	</div>
}
