package admin

import (
	shared "bandcash/models/shared"
	ctxi18n "github.com/invopop/ctxi18n/i18n"
)

templ FlagsContent(signupEnabled bool, paymentsEnabled bool, bypassLimitForSuperadminEnabled bool) {
	<div id="admin-flags">
		<div>
			@shared.ToggleSwitch(shared.ToggleSwitchProps{
				IsOn:      signupEnabled,
				OnClick:   "@post('/admin/flags/signup?value=' + (el.getAttribute('aria-checked') === 'true' ? '0' : '1'))",
				AriaLabel: ctxi18n.T(ctx, "admin.flags.signup"),
			})
			<span>{ ctxi18n.T(ctx, "admin.flags.signup") }</span>
		</div>
		<div>
			@shared.ToggleSwitch(shared.ToggleSwitchProps{
				IsOn:      paymentsEnabled,
				OnClick:   "@post('/admin/flags/payments?value=' + (el.getAttribute('aria-checked') === 'true' ? '0' : '1'))",
				AriaLabel: ctxi18n.T(ctx, "admin.flags.payments"),
			})
			<span>{ ctxi18n.T(ctx, "admin.flags.payments") }</span>
		</div>
		<div>
			@shared.ToggleSwitch(shared.ToggleSwitchProps{
				IsOn:      bypassLimitForSuperadminEnabled,
				OnClick:   "@post('/admin/flags/superadmin-limit-bypass?value=' + (el.getAttribute('aria-checked') === 'true' ? '0' : '1'))",
				AriaLabel: ctxi18n.T(ctx, "admin.flags.superadmin_limit_bypass"),
			})
			<span>{ ctxi18n.T(ctx, "admin.flags.superadmin_limit_bypass") }</span>
		</div>
	</div>
}
