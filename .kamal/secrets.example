# 1Password source config
# Fill these values, then Kamal will fetch all secrets below.
# account USER ID from `op account list` (URL/email may not work here)
OP_ACCOUNT=
# full 1Password path passed to --from (for example: Bandcash/prod)
OP_FROM=

# Fetch all required secrets once, then extract by key name.
SECRETS=$(kamal secrets fetch --adapter 1password --account "$OP_ACCOUNT" --from "$OP_FROM" KAMAL_REGISTRY_USERNAME KAMAL_REGISTRY_PASSWORD SUPERADMIN_EMAIL SMTP_HOST SMTP_PORT EMAIL_FROM SMTP_USERNAME SMTP_PASSWORD BETTER_STACK_URI BETTER_STACK_SOURCE_TOKEN)

# Some 1Password paths (for example section names with spaces) can arrive escaped.
# Normalize any leading/trailing backslash before JSON extraction.
SECRETS_JSON=${SECRETS#\\}
SECRETS_JSON=${SECRETS_JSON%\\}

KAMAL_REGISTRY_USERNAME=$(kamal secrets extract KAMAL_REGISTRY_USERNAME "$SECRETS_JSON")
KAMAL_REGISTRY_PASSWORD=$(kamal secrets extract KAMAL_REGISTRY_PASSWORD "$SECRETS_JSON")

SUPERADMIN_EMAIL=$(kamal secrets extract SUPERADMIN_EMAIL "$SECRETS_JSON")
SMTP_HOST=$(kamal secrets extract SMTP_HOST "$SECRETS_JSON")
SMTP_PORT=$(kamal secrets extract SMTP_PORT "$SECRETS_JSON")
EMAIL_FROM=$(kamal secrets extract EMAIL_FROM "$SECRETS_JSON")
SMTP_USERNAME=$(kamal secrets extract SMTP_USERNAME "$SECRETS_JSON")
SMTP_PASSWORD=$(kamal secrets extract SMTP_PASSWORD "$SECRETS_JSON")

BETTER_STACK_URI=$(kamal secrets extract BETTER_STACK_URI "$SECRETS_JSON")
BETTER_STACK_SOURCE_TOKEN=$(kamal secrets extract BETTER_STACK_SOURCE_TOKEN "$SECRETS_JSON")
