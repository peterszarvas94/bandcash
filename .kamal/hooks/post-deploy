#!/usr/bin/env bash
set -euo pipefail

KAMAL_BIN="$(mise which kamal)"

for accessory in better-stack; do
  if env -u GEM_HOME -u GEM_PATH "$KAMAL_BIN" accessory details "$accessory" >/dev/null 2>&1; then
    env -u GEM_HOME -u GEM_PATH "$KAMAL_BIN" accessory reboot "$accessory"
  else
    env -u GEM_HOME -u GEM_PATH "$KAMAL_BIN" accessory boot "$accessory"
  fi
done

ssh peti@bandcash "docker buildx prune -af --filter 'until=24h'" || true
