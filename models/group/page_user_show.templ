templ GroupUserInviteMain(data UserInvitePageData) {
	@shared.GroupTabs(data.GroupID, "users")
	<section class="details">
		<h1>{ data.UserRow.Email }</h1>
		if data.IsAdmin {
			<div class="actions">
				@GroupUserInviteDetailsActions(data)
			</div>
		}
	</section>
	<div class="pb">
		@shared.DetailsCard(fmt.Sprintf("group_user_invite_%s", data.UserRow.InviteID), []shared.DetailsRow{
			{Label: ctxi18n.T(ctx, "fields.role"), Value: func() string {
				if data.UserRow.Role == "admin" {
					return ctxi18n.T(ctx, "groups.role_admin")
