package group

import shared "bandcash/models/shared"

templ GroupRecentOutgoingPage(data GroupRecentOutgoingPageData) {
	@shared.BaseLayout(shared.BaseLayoutProps{
		Title:           data.Title,
		Crumbs:          data.Breadcrumbs,
		Signals:         data.Signals,
		Content:         GroupRecentOutgoingMain(data),
		ActiveUrl:       "/groups",
		IsAuthenticated: data.IsAuthenticated,
		IsSuperAdmin:    data.IsSuperAdmin,
		TabSidebar:      shared.GroupSidebar(data.GroupID, "recent_payouts"),
		TabToggleID:     data.GroupID,
	})
}
