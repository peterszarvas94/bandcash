package dev

import (
	"bandcash/internal/assets"
	shared "bandcash/models/shared"
)

templ DevPage(data DevPageData) {
	@shared.BaseLayout(shared.BaseLayoutProps{
		Title:           data.Title,
		Crumbs:          data.Breadcrumbs,
		Signals:         data.Signals,
		Content:         shared.CommonContent(DevMain(data.LinkSelector)),
		ActiveUrl:       "/dev",
		IsAuthenticated: data.IsAuthenticated,
		IsSuperAdmin:    false,
	})
	<script type="module" src={ assets.AssetPath("js/rate_limit_tester.js") }></script>
	<script type="module" src={ assets.AssetPath("js/body_limit_tester.js") }></script>
	<script type="module" src={ assets.AssetPath("js/table_query_tester.js") }></script>
}
