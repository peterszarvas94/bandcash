package shared

import (
	"bandcash/internal/utils"
	icons "bandcash/models/shared/icons"
)

templ Notifications() {
	<div id="notifications-popover">
		<ul>
			for _, item := range utils.NotificationsFromContext(ctx) {
				<li id={ "notification-item-" + item.ID } class={ "notification-" + item.Kind } data-notification-id={ item.ID } data-created-at-ms={ item.Created.UnixMilli() }>
					<p>{ item.Message }</p>
					<button type="button" aria-label="Close notification" title="Close notification">
						@icons.X(templ.Attributes{"class": "icon"})
					</button>
				</li>
			}
		</ul>
	</div>
}
